{
  "id": "internal.fl_resident.blocks.tax_flags",
  "type": "pipeline",
  "description": "Регуляторные флаги: обязательность, тип и допустимое значение",
  "strict": false,
  "flow": [
    {
      "rule": "library.tax.foreign_tax_resident_required"
    },
    {
      "condition": "library.tax.cond_foreign_tax_resident_type_if_present"
    },
    {
      "condition": "internal.fl_resident.blocks.tax_flags.cond_foreign_tax_resident_not_true_if_boolean"
    },
    {
      "rule": "library.tax.us_tax_resident_required"
    },
    {
      "condition": "library.tax.cond_us_tax_resident_type_if_present"
    },
    {
      "condition": "internal.fl_resident.blocks.tax_flags.cond_us_tax_resident_not_true_if_boolean"
    },
    {
      "rule": "library.tax.us_resident_required"
    },
    {
      "condition": "library.tax.cond_us_resident_type_if_present"
    },
    {
      "condition": "internal.fl_resident.blocks.tax_flags.cond_us_resident_not_true_if_boolean"
    }
  ],
  "entrypoint": false
}
