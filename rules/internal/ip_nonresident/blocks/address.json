{
  "id": "internal.ip_nonresident.blocks.address",
  "type": "pipeline",
  "description": "Проверки адреса регистрации и почтового адреса",
  "strict": false,
  "flow": [
    {
      "rule": "library.address.registration_country_required"
    },
    {
      "condition": "internal.ip_nonresident.blocks.address.registration_country_if_present"
    },
    {
      "condition": "library.address.cond_registration_fias_structure_for_ru"
    },
    {
      "condition": "library.address.cond_postal_address_if_present"
    },
    {
      "condition": "library.address.cond_postal_if_present"
    },
    {
      "condition": "library.address.cond_region_code_if_present"
    },
    {
      "condition": "library.address.cond_region_name_if_present"
    },
    {
      "condition": "library.address.cond_city_if_present"
    },
    {
      "condition": "library.address.cond_locality_if_present"
    },
    {
      "condition": "library.address.cond_street_if_present"
    },
    {
      "condition": "library.address.cond_street_type_if_present"
    },
    {
      "condition": "library.address.cond_house_if_present"
    },
    {
      "condition": "library.address.cond_building_if_present"
    },
    {
      "condition": "library.address.cond_flat_if_present"
    },
    {
      "condition": "library.ip_nonresident.address.cond_address_line_if_present"
    }
  ],
  "entrypoint": false
}
