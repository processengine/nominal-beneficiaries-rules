{
  "id": "internal.ip_nonresident.blocks.tax_flags",
  "type": "pipeline",
  "description": "Проверка налоговых признаков ИП-нерезидента, FATCA/US и условных иностранных налоговых сведений",
  "strict": false,
  "flow": [
    {
      "rule": "library.tax.us_tax_resident_bool"
    },
    {
      "rule": "internal.ip_nonresident.blocks.tax_flags.us_tax_resident_not_true"
    },
    {
      "rule": "library.tax.us_resident_bool"
    },
    {
      "rule": "internal.ip_nonresident.blocks.tax_flags.us_resident_not_true"
    },
    {
      "condition": "library.tax.cond_foreign_tax_trigger_block"
    },
    {
      "condition": "library.tax.cond_phone_foreign_required_if_triggered_and_rf_phone_missing"
    },
    {
      "condition": "library.common.cond_phone_foreign_if_present"
    }
  ],
  "entrypoint": false
}
