{
  "id": "library.tax.cond_foreign_tax_trigger_block",
  "type": "condition",
  "description": "Если указан иностранный документ или адрес не в России, то проверяем данные иностранного налогового резидентства",
  "when": {
    "any": [
      "library.tax.pred_is_foreign_id_doc_true",
      "library.tax.pred_registration_country_non_ru",
      "library.tax.pred_postal_country_non_ru"
    ]
  },
  "steps": [
    {
      "rule": "library.tax.foreign_tax_resident_required"
    },
    {
      "condition": "library.tax.cond_foreign_tax_resident_type_if_present"
    },
    {
      "condition": "library.tax.cond_foreign_tax_resident_true_if_boolean"
    },
    {
      "rule": "library.tax.foreign_country_required"
    },
    {
      "rule": "library.tax.foreign_country_format"
    },
    {
      "rule": "library.tax.foreign_country_not_us"
    },
    {
      "rule": "library.tax.foreign_tin_or_reason"
    },
    {
      "rule": "library.tax.foreign_address_or_postal_required"
    },
    {
      "condition": "library.tax.cond_foreign_address_if_present"
    },
    {
      "condition": "library.tax.cond_tin_if_present"
    },
    {
      "condition": "library.tax.cond_reason_if_present"
    }
  ]
}
