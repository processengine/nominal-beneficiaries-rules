{
  "id": "library.common.email_format",
  "type": "rule",
  "description": "Email должен быть валидным",
  "role": "check",
  "operator": "matches_regex",
  "level": "ERROR",
  "code": "BEN.CONTACTS.EMAIL.FORMAT",
  "message": "Некорректный email",
  "field": "beneficiary.contacts.email",
  "value": "^[^@\\s]+@[^@\\s]+\\.[^@\\s]+$"
}
