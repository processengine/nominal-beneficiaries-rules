{
  "id": "library.nonresident.cond_add_doc_issue_date_end_order_if_dates_ok",
  "type": "condition",
  "description": "Если даты дополнительного документа корректны и срок не истёк, проверяем порядок дат",
  "when": {
    "all": [
      "library.nonresident.pred_add_doc_issueDate_format_valid",
      "library.nonresident.pred_add_doc_issueDateEnd_format_valid",
      "library.nonresident.pred_add_doc_issueDateEnd_not_expired"
    ]
  },
  "steps": [
    {
      "rule": "library.nonresident.add_doc_issue_date_end_after_start"
    }
  ]
}
