{
  "id": "library.documents.issuer_no_extra_spaces",
  "type": "rule",
  "description": "Орган выдачи не должен содержать лишние пробелы",
  "role": "check",
  "operator": "matches_regex",
  "level": "WARNING",
  "code": "BEN.IDDOC.ISSUER.SPACES",
  "message": "Поле beneficiary.idDoc.issuer содержит лишние пробелы",
  "field": "beneficiary.idDoc.issuer",
  "value": "^(?!\\s)(?!.*\\s$)(?!.*\\s{2,}).+$"
}
