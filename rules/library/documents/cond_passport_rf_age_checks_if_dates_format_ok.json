{
  "id": "library.documents.cond_passport_rf_age_checks_if_dates_format_ok",
  "type": "condition",
  "description": "Если даты рождения и выдачи паспорта корректны, проверяем возраст и срок замены паспорта",
  "when": {
    "all": [
      "library.fl.pred_birth_date_format_valid",
      "library.documents.pred_issue_date_format_valid"
    ]
  },
  "steps": [
    {
      "rule": "library.documents.passport_rf_issue_date_after_14"
    },
    {
      "rule": "library.documents.passport_rf_valid_after_20"
    },
    {
      "rule": "library.documents.passport_rf_valid_after_45"
    }
  ]
}
