{
  "id": "library.documents.cond_passport_rf_fields",
  "type": "condition",
  "description": "Если тип документа = паспорт РФ, проверяем паспортные поля и код подразделения",
  "when": {
    "all": [
      "library.documents.pred_type_code_passport_rf"
    ]
  },
  "steps": [
    {
      "rule": "library.documents.series_required"
    },
    {
      "condition": "library.documents.cond_series_format_if_present"
    },
    {
      "rule": "library.documents.number_passport_rf_format"
    },
    {
      "rule": "library.documents.issuer_code_required"
    },
    {
      "condition": "library.documents.cond_issuer_code_format_if_present"
    },
    {
      "condition": "library.documents.cond_passport_rf_age_checks_if_dates_format_ok"
    }
  ]
}
