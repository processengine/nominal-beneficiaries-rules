{
  "id": "library.ul.common.cond_status_end_if_present",
  "type": "condition",
  "description": "Если дата окончания участия указана, проверяем формат и порядок дат",
  "when": {
    "all": [
      "library.common.pred_status_end_present"
    ]
  },
  "steps": [
    {
      "rule": "library.ul.common.status_end_format"
    },
    {
      "condition": "library.ul.common.cond_status_end_order_if_format_ok"
    }
  ]
}
