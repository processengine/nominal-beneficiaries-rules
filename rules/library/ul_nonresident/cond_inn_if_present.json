{
  "id": "library.ul_nonresident.cond_inn_if_present",
  "type": "condition",
  "description": "Если ИНН указан, то проверяем длину, маску и контрольный разряд",
  "when": {
    "all": [
      "library.ul_nonresident.pred_inn_present"
    ]
  },
  "steps": [
    {
      "rule": "library.ul_nonresident.inn_format_10"
    },
    {
      "condition": "library.ul_nonresident.cond_inn_mask_if_format_ok"
    },
    {
      "condition": "library.ul_nonresident.cond_inn_valid_if_mask_ok"
    }
  ]
}
