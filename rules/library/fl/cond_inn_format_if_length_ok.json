{
  "id": "library.fl.cond_inn_format_if_length_ok",
  "type": "condition",
  "description": "Если длина ИНН корректна, то проверяем повторы и контрольный разряд",
  "when": {
    "all": [
      "library.fl.pred_inn_length_valid"
    ]
  },
  "steps": [
    {
      "rule": "library.fl.inn_not_repeated"
    },
    {
      "rule": "library.fl.inn_valid"
    }
  ]
}
