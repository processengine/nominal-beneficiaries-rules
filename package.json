{
  "name": "@processengine/nominal-beneficiaries-rules",
  "version": "1.1.3",
  "description": "Пакет правил проверок бенефициаров номинальных счетов для jsonspecs",
  "license": "UNLICENSED",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/processengine/nominal-beneficiaries-rules.git"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "validate": "jsonspecs validate --fail-on-warning",
    "build": "jsonspecs build --fail-on-warning",
    "test:operators": "node --test tests/operators.test.js",
    "test:rules": "jsonspecs test",
    "test": "npm run validate && npm run test:operators && npm run test:rules && npm run build && npm run verify:package",
    "verify:package": "node scripts/verify-package.mjs",
    "release:check": "npm test && npm audit --omit=dev && npm pack --dry-run --ignore-scripts && node scripts/verify-release.mjs",
    "prepublishOnly": "node scripts/verify-publish-context.mjs && npm run release:check",
    "version:set": "node scripts/set-version.mjs"
  },
  "dependencies": {
    "@jsonspecs/rules": "4.0.0"
  },
  "devDependencies": {
    "jsonspecs-cli": "4.0.1"
  },
  "files": [
    "AGENTS.md",
    "CHANGELOG.md",
    "dist/",
    "docs/",
    "manifest.json",
    "operators/",
    "rules/",
    "samples/"
  ]
}
